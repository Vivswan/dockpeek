#!/bin/bash
# DockPeek pre-commit hook: run SwiftLint + SwiftFormat check on staged Swift files
# Skips if tools aren't installed (doesn't block commits on machines without them)
#
# Install: make hooks  (or: git config core.hooksPath hooks)

set -euo pipefail

# SwiftLint requires full Xcode.app (not just Command Line Tools)
if [ -d "/Applications/Xcode.app" ]; then
    export DEVELOPER_DIR="/Applications/Xcode.app/Contents/Developer"
fi

# Only check staged .swift files (excluding Vendor)
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' | grep -v 'Vendor/' || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

FAILED=0

# SwiftLint (if installed)
if command -v swiftlint &>/dev/null; then
    echo "Running SwiftLint..."
    echo "$STAGED" | xargs swiftlint lint --config .swiftlint.yml --quiet 2>/dev/null || FAILED=1
else
    echo "⚠️  SwiftLint not installed (brew install swiftlint) — skipping"
fi

# SwiftFormat check (if installed)
if command -v swiftformat &>/dev/null; then
    echo "Running SwiftFormat check..."
    echo "$STAGED" | xargs swiftformat --lint --quiet 2>/dev/null || {
        echo "❌ SwiftFormat: some files need formatting. Run 'make format' to fix."
        FAILED=1
    }
else
    echo "⚠️  SwiftFormat not installed (brew install swiftformat) — skipping"
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "❌ Pre-commit checks failed. Fix issues above or use 'git commit --no-verify' to skip."
    exit 1
fi

echo "✅ Pre-commit checks passed"
